<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 450" width="100%" height="100%">
  <!-- Pure black background that gets screened out -->
  <rect width="100%" height="100%" fill="#000000" />
  
  <g stroke="#cfdadb" fill="none" stroke-linecap="round" stroke-linejoin="round">
    <!-- Lip (top rim) – layered strokes to mimic dry charcoal brush -->
    <path d="M 115 106 C 130 102, 170 102, 185 106" stroke-width="2.5" opacity="0.9" />
    <path d="M 118 107 C 132 104, 168 104, 182 107" stroke-width="1.2" stroke="#ffffff" opacity="0.6" />
    <path d="M 110 109 C 135 111, 165 111, 190 109" stroke-width="1.8" stroke="#a0b3b4" opacity="0.8" />
    <path d="M 125 112 Q 150 115 175 112" stroke-width="1.0" opacity="0.5" />

    <!-- Neck profile -->
    <path d="M 119 109 Q 124 124, 116 138" stroke-width="2.2" />
    <path d="M 118 111 Q 122 124, 115 137" stroke-dasharray="4,2" stroke-width="1.5" stroke="#ffffff" opacity="0.7" />
    <path d="M 181 109 Q 176 124, 184 138" stroke-width="2.2" />
    <path d="M 182 111 Q 178 124, 185 137" stroke-dasharray="3,2" stroke-width="1.5" stroke="#ffffff" opacity="0.7" />

    <!-- Shoulder profile - high, rounded, dry brush strokes -->
    <path d="M 116 138 C 105 148, 85 168, 80 205" stroke-width="2.8" />
    <path d="M 115 139 C 107 147, 88 166, 83 203" stroke-width="1.5" stroke="#ffffff" opacity="0.6" />
    <path d="M 118 137 C 102 149, 82 170, 78 208" stroke-width="1.0" stroke-dasharray="8,4" opacity="0.5" />

    <path d="M 184 138 C 195 148, 215 168, 220 205" stroke-width="2.8" />
    <path d="M 185 139 C 193 147, 212 166, 217 203" stroke-width="1.5" stroke="#ffffff" opacity="0.6" />
    <path d="M 182 137 C 198 149, 218 170, 222 208" stroke-width="1.0" stroke-dasharray="8,4" opacity="0.5" />

    <!-- Main belly section of the meiping -->
    <path d="M 80 205 C 80 235, 85 275, 102 320" stroke-width="3.2" />
    <path d="M 82 205 C 82 233, 87 273, 104 318" stroke-width="1.5" stroke="#ffffff" opacity="0.7" />
    <path d="M 78 212 C 78 240, 83 280, 100 325" stroke-width="1.2" stroke-dasharray="15,5,3,8" opacity="0.6" />
    <path d="M 83 220 C 83 245, 87 275, 101 310" stroke-width="0.8" stroke-dasharray="5,10" opacity="0.4" />

    <path d="M 220 205 C 220 235, 215 275, 198 320" stroke-width="3.2" />
    <path d="M 218 205 C 218 233, 213 273, 196 318" stroke-width="1.5" stroke="#ffffff" opacity="0.7" />
    <path d="M 222 212 C 222 240, 217 280, 200 325" stroke-width="1.2" stroke-dasharray="12,6,4,7" opacity="0.6" />
    <path d="M 217 220 C 217 245, 213 275, 199 310" stroke-width="0.8" stroke-dasharray="5,10" opacity="0.4" />

    <!-- Lower taper Section with dynamic ink breaks representing "枯笔" -->
    <path d="M 102 320 C 114 355, 122 392, 124 408" stroke-width="2.6" />
    <path d="M 104 320 C 115 354, 123 390, 125 406" stroke-width="1.2" stroke="#ffffff" opacity="0.5" />
    <path d="M 99 328 C 111 360, 119 395, 121 411" stroke-width="1.5" stroke-dasharray="10,6" opacity="0.6" />

    <path d="M 198 320 C 186 355, 178 392, 176 408" stroke-width="2.6" />
    <path d="M 196 320 C 185 354, 177 390, 175 406" stroke-width="1.2" stroke-dasharray="12,5" opacity="0.5" />
    <path d="M 201 328 C 189 360, 181 395, 179 411" stroke-width="1.5" stroke-dasharray="12,5" opacity="0.6" />

    <!-- Foot/Base -->
    <path d="M 124 408 C 135 410, 165 410, 176 408" stroke-width="2.5" />
    <path d="M 122 410 C 135 412, 165 412, 178 410" stroke-width="1.2" stroke-dasharray="6,3" opacity="0.8" />
    <path d="M 120 411 C 135 413, 165 413, 180 411" stroke-width="1.0" opacity="0.5" />
    <path d="M 126 406 L 174 406" stroke-width="0.5" stroke="#ffffff" opacity="0.3" />
  </g>
</svg>
